{
  "_description": "Next.js: vercel CLI + eslint/tailwind extensions, persisted ~/.local/share/com.vercel.cli (Node.js is in base)",
  "features": {},
  "postStartCommand": "bash -lc 'if [ -f package-lock.json ]; then npm ci --ignore-scripts; fi'",
  "mounts": [
    "source=vercel-config,target=/home/vscode/.local/share/com.vercel.cli,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "remoteEnv": {
    "VERCEL_TOKEN": "${localEnv:VERCEL_TOKEN}"
  },
  "_bootstrap": [
    "# --- nextjs/vercel ---",
    "sunaba_fix_config_dir \"$HOME/.local/share/com.vercel.cli\"",
    "npm install -g vercel@latest"
  ],
  "_dependabot": {
    "package-ecosystem": "npm",
    "directory": "/",
    "schedule": { "interval": "weekly" }
  }
}
