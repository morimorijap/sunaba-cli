{
  "_description": "AI agent API keys + persisted OAuth/session state for claude/codex/gemini CLIs",
  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}"
  },
  "mounts": [
    "source=claude-config,target=/home/vscode/.claude,type=volume",
    "source=codex-config,target=/home/vscode/.codex,type=volume",
    "source=gemini-config,target=/home/vscode/.gemini,type=volume"
  ],
  "_bootstrap": [
    "# --- ai-agents ---",
    "echo 'AI agent API keys injected via remoteEnv'",
    "sunaba_fix_config_dir \"$HOME/.claude\"",
    "sunaba_fix_config_dir \"$HOME/.codex\"",
    "sunaba_fix_config_dir \"$HOME/.gemini\"",
    "chmod 700 \"$HOME/.claude\" \"$HOME/.codex\" \"$HOME/.gemini\" 2>/dev/null || true",
    "# Claude Code keeps two state locations: ~/.claude/ (.credentials.json,",
    "# settings, projects) is mounted as a named volume, but ~/.claude.json",
    "# (a single JSON with MCP servers + per-project trust + UI toggles) lives",
    "# at $HOME's root and is wiped on every devcontainer rebuild. Move it",
    "# inside the persistent volume and symlink so both rebuild and CLI",
    "# upgrades survive.",
    "if [ -f \"$HOME/.claude.json\" ] && [ ! -L \"$HOME/.claude.json\" ]; then",
    "  if [ ! -f \"$HOME/.claude/claude.json\" ]; then",
    "    mv \"$HOME/.claude.json\" \"$HOME/.claude/claude.json\"",
    "  else",
    "    rm -f \"$HOME/.claude.json\"",
    "  fi",
    "fi",
    "if [ ! -e \"$HOME/.claude.json\" ] && [ -f \"$HOME/.claude/claude.json\" ]; then",
    "  ln -s \"$HOME/.claude/claude.json\" \"$HOME/.claude.json\"",
    "fi"
  ]
}
